{
  "_comment": "License policy enforced by scripts/licenseCheck.ts. allow = SPDX strings considered safe. deny = anything containing one of these substrings (case-insensitive) fails. exceptions = override license string for a specific package name when its package.json is wrong or ambiguous.",
  "allow": [
    "MIT",
    "MIT-0",
    "ISC",
    "BSD",
    "BSD-2-Clause",
    "BSD-3-Clause",
    "Apache-2.0",
    "Apache 2.0",
    "CC0-1.0",
    "CC-BY-4.0",
    "Unlicense",
    "0BSD",
    "Python-2.0",
    "BlueOak-1.0.0",
    "WTFPL"
  ],
  "deny": [
    "GPL-2.0",
    "GPL-3.0",
    "AGPL",
    "LGPL",
    "SSPL",
    "Commons Clause",
    "BUSL"
  ],
  "exceptions": {
    "@anthropic-ai/claude-agent-sdk": "Apache-2.0",
    "@img/sharp-libvips-darwin-arm64": "Apache-2.0",
    "@img/sharp-libvips-darwin-x64": "Apache-2.0",
    "@img/sharp-libvips-linux-arm": "Apache-2.0",
    "@img/sharp-libvips-linux-arm64": "Apache-2.0",
    "@img/sharp-libvips-linux-s390x": "Apache-2.0",
    "@img/sharp-libvips-linux-x64": "Apache-2.0",
    "@img/sharp-libvips-linuxmusl-arm64": "Apache-2.0",
    "@img/sharp-libvips-linuxmusl-x64": "Apache-2.0"
  }
}
